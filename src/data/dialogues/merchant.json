{
  "0":  ["어서오세요. 뭘 사러 오셨나요?", "오늘 들어온 씨앗 있어요."],
  "10": ["자주 오시는 분이네요!", "좋은 물건 있으면 알려드릴게요."],
  "20": ["단골손님이 되셨군요.", "오늘은 뭐가 필요하세요?"],
  "30": ["당신 작물은 질이 좋더라고요.", "제가 좋은 값에 사드릴게요."],
  "40": ["믿을 수 있는 거래처예요.", "다음에 좋은 물건 들어오면 연락할게요."],
  "50": ["특별 가격에 드릴게요!", "항상 감사히 생각해요."],
  "60": ["이 마을 최고의 생산자예요.", "작물 상태가 정말 좋아요."],
  "70": ["당신 덕분에 장사가 잘 돼요.", "오늘도 좋은 거래 합시다."],
  "80": ["오래 거래하다 보니 정이 들었어요.", "특별히 잘 봐드릴게요."],
  "90": ["이젠 가족 같은 느낌이에요.", "항상 최선을 다해 도울게요."],
  "100":["이 마을에서 제일 믿는 사람이에요."]
