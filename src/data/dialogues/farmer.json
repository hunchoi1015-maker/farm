{
  "0":  ["안녕하세요. 농사 지으러 오셨나요?", "처음 보는 얼굴이네요."],
  "10": ["요즘 자주 보이시네요!", "밭일이 몸에 배셨군요."],
  "20": ["오늘도 열심히 하셨어요?", "물 주기 잊지 마세요."],
  "30": ["같이 일하면 든든하더라고요.", "씨앗 고르는 법 알려드릴까요?"],
  "40": ["우리 마을에 잘 오셨어요.", "덕분에 마을이 활기차네요."],
  "50": ["이제 제가 도와드릴게요!", "믿고 맡겨주세요."],
  "60": ["요즘 수확이 잘 되고 있나요?", "비 오는 날엔 쉬어가세요."],
  "70": ["당신 덕분에 저도 힘이 나요.", "올해 농사는 잘 될 것 같아요."],
  "80": ["이 마을에 와줘서 정말 고마워요.", "같이 농사짓는 게 즐거워요."],
  "90": ["평생 이웃으로 지내고 싶어요.", "당신은 제 소중한 친구예요."],
  "100":["함께라면 어떤 계절도 두렵지 않아요."]
